{
  "name": "gnome-warrior",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "biome check --write",
    "lint": "biome check",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "p5": "^1.11.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@types/p5": "^1.7.7",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
